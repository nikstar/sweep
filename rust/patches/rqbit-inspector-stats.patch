+    pub fn update_extended_handshake(&mut self, handshake: &ExtendedHandshake<ByteBuf<'_>>) {
+        self.client_name = handshake.v.as_ref().and_then(|client| {
+            let client = String::from_utf8_lossy(client.as_ref()).trim().to_owned();
+            if client.is_empty() {
