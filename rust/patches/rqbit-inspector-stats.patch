+#[derive(Clone, Debug)]
+struct TrackerAnnounceOutcome {
+    interval: Duration,
+    seeders: Option<u64>,
+    leechers: Option<u64>,
+    downloads: Option<u64>,
+    peer_count: u64,
+}
+
+impl TrackerCommsState {
+    pub fn snapshot(&self) -> Vec<TrackerCommsTrackerStats> {
+        let Ok(state) = self.inner.read() else {
+            return Vec::new();
+        };
+        let mut trackers = state.values().cloned().collect::<Vec<_>>();
+        trackers.sort_by(|lhs, rhs| lhs.url.cmp(&rhs.url));
+        trackers
+    }
+
+    fn track(&self, tracker: &SupportedTracker) {
+        let Ok(mut state) = self.inner.write() else {
+            return;
+        };
+        let url = tracker.url().to_string();
+        state
+            .entry(url.clone())
+            .or_insert(TrackerCommsTrackerStats {
+                url,
+                kind: tracker.kind().to_owned(),
+                status: "Waiting".to_owned(),
+                last_error: None,
+                last_announce_unix_seconds: None,
+                next_announce_unix_seconds: None,
+                seeders: None,
+                leechers: None,
+                downloads: None,
+                last_peer_count: None,
+            });
+    }
+
+    fn mark_announcing(&self, tracker_url: &Url) {
+        self.update(tracker_url, |stats| {
+            stats.status = "Announcing".to_owned();
+        });
+    }
+
+    fn mark_success(&self, tracker_url: &Url, outcome: &TrackerAnnounceOutcome) {
+        let now = unix_now();
+        self.update(tracker_url, |stats| {
+            stats.status = "Working".to_owned();
+            stats.last_error = None;
+            stats.last_announce_unix_seconds = Some(now);
+            stats.next_announce_unix_seconds = Some(now.saturating_add(outcome.interval.as_secs()));
+            stats.seeders = outcome.seeders;
+            stats.leechers = outcome.leechers;
+            stats.downloads = outcome.downloads;
+            stats.last_peer_count = Some(outcome.peer_count);
+        });
+    }
+
+    fn mark_error(&self, tracker_url: &Url, error: String, retry_in: Duration) {
+        let now = unix_now();
+        self.update(tracker_url, |stats| {
+            stats.status = "Error".to_owned();
+            stats.last_error = Some(error);
+            stats.next_announce_unix_seconds = Some(now.saturating_add(retry_in.as_secs()));
+        });
+    }
+
+    fn update(&self, tracker_url: &Url, f: impl FnOnce(&mut TrackerCommsTrackerStats)) {
+        let Ok(mut state) = self.inner.write() else {
+            return;
+        };
+        let url = tracker_url.to_string();
+        let stats = state
+            .entry(url.clone())
+            .or_insert(TrackerCommsTrackerStats {
+                url,
+                kind: tracker_url.scheme().to_ascii_uppercase(),
+                status: "Waiting".to_owned(),
+                last_error: None,
+                last_announce_unix_seconds: None,
+                next_announce_unix_seconds: None,
+                seeders: None,
+                leechers: None,
+                downloads: None,
+                last_peer_count: None,
+            });
+        f(stats);
+    }
+}
+
+fn unix_now() -> u64 {
+    SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|duration| duration.as_secs())
+        .unwrap_or_default()
 }
 
