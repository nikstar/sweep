+            flags.push("ut_metadata".to_owned());
+        }
+        if handshake.m.ut_pex.is_some() {
+            flags.push("ut_pex".to_owned());
+        }
+        if handshake.metadata_size.is_some() {
+            flags.push("metadata".to_owned());
+        }
+        if handshake.reqq.is_some() {
+            flags.push("reqq".to_owned());
+        }
+        if handshake.upload_only.is_some_and(|value| value != 0) {
+            flags.push("upload_only".to_owned());
+        }
+        self.feature_flags = flags;
+    }
 }
