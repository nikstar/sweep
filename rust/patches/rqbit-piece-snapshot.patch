+fn snapshot_piece_tracker(
+    lengths: &Lengths,
+    chunks: &ChunkTracker,
+    pieces: Option<&PieceTracker>,
+) -> Vec<TorrentPieceSnapshot> {
+    let selected = chunks.get_selected_pieces();
+    lengths
+        .iter_piece_infos()
+        .map(|piece| {
+            let index = piece.piece_index;
+            let idx = index.get() as usize;
+            let status = if chunks.is_piece_have(index) {
+                TorrentPieceStatus::Downloaded
+            } else if pieces
+                .map(|pieces| pieces.is_inflight(index))
+                .unwrap_or(false)
+            {
+                TorrentPieceStatus::Downloading
+            } else if selected.get(idx).map(|value| *value).unwrap_or(false) {
+                TorrentPieceStatus::Needed
+            } else {
+                TorrentPieceStatus::Skipped
+            };
+
+            TorrentPieceSnapshot {
+                index: index.get(),
+                length: piece.len,
+                status,
+            }
+        })
+        .collect()
+}
+
+fn snapshot_unknown_pieces(lengths: &Lengths) -> Vec<TorrentPieceSnapshot> {
+    lengths
+        .iter_piece_infos()
+        .map(|piece| TorrentPieceSnapshot {
+            index: piece.piece_index.get(),
+            length: piece.len,
+            status: TorrentPieceStatus::Unknown,
+        })
+        .collect()
+}
